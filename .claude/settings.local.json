{
  "permissions": {
    "allow": [
      "Bash(pnpm add *)",
      "Bash(npx astro *)",
      "Bash(Start-Process -NoNewWindow -FilePath \"npx\" -ArgumentList \"astro\",\"dev\",\"--port\",\"4321\")",
      "Bash(Start-Sleep -Seconds 4)",
      "Bash(Write-Host \"Dev server started\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:4321/)"
    ]
  }
}
